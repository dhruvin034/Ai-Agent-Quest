CHUNK_OVERLAP = 150               # Character overlap between chunks
EMBEDDING_MODEL = "BAAI/bge-small-en-v1.5"
TEMPERATURE_RAG = 0.2             # Factual responses
TEMPERATURE_CHAT = 0.7            # Conversational responses
